pdxmesh = {
	name = "hull_aircraftcarrier_modern_light_mesh"
	file = "hull_aircraftcarrier_modern.mesh"

	meshsettings = {
		name = "LOD_Group|LOD_0|ship_hull_0.001"
		index = 0
		texture_diffuse = "ship_aircraftcarrier_modern_hull_light_diffuse.dds"
		texture_normal = "ship_aircraftcarrier_modern_hull_light_normal.dds"
		texture_specular = "ship_aircraftcarrier_modern_hull_light_properties.dds"
		texture = { file = "ship_aircraftcarrier_modern_hull_light_colormask.dds" index = 6 }

		texture = { file = "damage_metal.dds" index = 3 }					# Decal Texture
		texture = { file = "hull_damage_int_metal_diffuse.dds" index = 5 } 	# Interior Texture
		
        shader = "standard"
        shader_file = "gfx/FX/pdxmesh.shader"
        additional_shader_defines = { "UNIT_COLOR" "EMISSIVE_NIGHT" "DYNAMIC_SHIP_SHADER" "SHIP_INTERIOR" }
    	}
}

entity = {
	name = "hull_aircraftcarrier_modern_light_entity"
	pdxmesh = "hull_aircraftcarrier_modern_light_mesh"
}

