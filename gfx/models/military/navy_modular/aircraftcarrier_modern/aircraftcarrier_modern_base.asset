pdxmesh = {
	name = "aircraftcarrier_modern_base_mesh"
	file = "aircraftcarrier_modern_base.mesh"

	meshsettings = {
		name = "LOD_Group|LOD_0|ship_base_0.001"
		index = 0
		texture_diffuse = "ship_aircraftcarrier_modern_base_diffuse.dds"
		texture_normal = "ship_aircraftcarrier_modern_base_normal.dds"
		texture_specular = "ship_aircraftcarrier_modern_base_properties.dds"
		texture = { file = "ship_aircraftcarrier_modern_base_colormask.dds" index = 6 }
		shader = "standard"
		additional_shader_defines = { "UNIT_COLOR" "EMISSIVE_NIGHT" }
		shader_file = "gfx/FX/pdxmesh.shader"
	}

	meshsettings = {
		name = "LOD_Group|LOD_0|ship_flag_0.001"
		index = 0
		texture_diffuse = "flag_wrinkles_diffuse.dds"
		texture_normal = "flag_wrinkles_normal.dds"
		texture_specular = "flag_wrinkles_properties.dds"
		shader = "standard_flag_basic"
		shader_file = "gfx/FX/pdxmesh.shader"
		additional_shader_defines = { "COA_TEXTURE" }
	}

	meshsettings = {
		name = "LOD_Group|LOD_0|ship_ropes_0.001"
		index = 0
		texture_diffuse = "generic_ship_alpha_diffuse.dds"
		texture_normal = "generic_ship_alpha_normal.dds"
		texture_specular = "generic_ship_alpha_properties.dds"
		shader = "standard"
		shader_file = "gfx/FX/pdxmesh.shader"
	}
}

entity = {
	name = "aircraftcarrier_modern_base_entity"
	pdxmesh = "aircraftcarrier_modern_base_mesh"

	default_state = "move"

	state = { name = "idle"
		event = { time = 0 keep_sound = yes sound  = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_idle" } }
	}

	state = { name = "move"
		event = { time = 0 keep_sound = yes sound  = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_moving" } }
		event = { time = 0 trigger_once = yes keep_sound = no sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_moving_start" } }
	}

	state = { name = "move_local"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_moving_local" } }
		event = { time = 0 trigger_once = yes keep_sound = no sound  = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_moving_start" } }
	}

	state = { name = "move_ship_viewer"
		event = { time = 0 keep_sound = yes sound = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_moving_ship_viewer" } }
	}

	state = { name = "combat"
		event = { time = 0 keep_sound = yes sound  = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_combat" } }
	}
	
	state = { name = "destroyed"
		event = { time = 0 keep_sound = yes sound  = { soundeffect = "event:/SFX/Animation/vehicles/naval/fleet/cruisers/aircraft_carrier/anm_ship_aircraftcarrier_destroyed" } }
	}	
}
